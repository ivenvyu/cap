{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cap.image_reranker.v2_2_1.pair_feature_snapshot",
  "title": "PairFeatureSnapshot schema",
  "description": "Immutable pair feature snapshot schema for CAP Image Reranker v2.2.1, with backward-compatible v2.2.2 image-layout snapshot id extension.",
  "type": "object",
  "additionalProperties": false,
  "x_metadata": {
    "spec_version": "v2.2.1",
    "freeze_date": "2026-05-10",
    "decision_log": "docs/design_history/v2_2_1_freeze.md",
    "status": "frozen",
    "superseded_by": null
  },
  "required": [
    "feature_snapshot_id",
    "snapshot_version",
    "batch_id",
    "created_at",
    "pair_id",
    "campaign_id",
    "image_id",
    "feature_status",
    "provenance",
    "features"
  ],
  "properties": {
    "feature_snapshot_id": {
      "type": "string",
      "description": "Immutable feature snapshot id referenced by ReviewEvent. v2.2.2 includes layout_spec_id.",
      "pattern": "^feat_[A-Za-z0-9_\\-:.]+__.+__.+(?:__.+)?$"
    },
    "snapshot_version": {
      "type": "string",
      "description": "Feature schema version, e.g. v2_2_1."
    },
    "batch_id": {
      "type": "string",
      "description": "Review queue or scoring batch id that produced this snapshot."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "pair_id": {
      "type": "string"
    },
    "campaign_id": {
      "type": "string"
    },
    "image_id": {
      "type": "string"
    },
    "layout_spec_id": {
      "type": [
        "string",
        "null"
      ],
      "default": null
    },
    "duplicate_group_id": {
      "type": [
        "string",
        "null"
      ],
      "default": null
    },
    "feature_status": {
      "type": "string",
      "enum": [
        "diagnostic_only",
        "calibrated_validation",
        "production_candidate"
      ],
      "description": "Whether feature values are diagnostic only or calibrated."
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_image_asset_version",
        "campaign_version",
        "layout_spec_version",
        "clip_embedding_version",
        "dinov2_embedding_version",
        "region_safety_version",
        "critic_version"
      ],
      "properties": {
        "raw_image_asset_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "campaign_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "layout_spec_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "clip_embedding_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "dinov2_embedding_version": {
          "type": [
            "string",
            "null"
          ]
        },
